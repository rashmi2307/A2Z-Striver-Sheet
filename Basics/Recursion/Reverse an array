# Reverse an array

# Given an array arr of n elements. The task is to reverse the given array. The reversal of array should be inplace.

class Solution:
    def reverse(self, arr: list, n: int) -> None:
        p1 = 0
        p2 = len(arr)-1
        while p1<p2:
            arr[p1],arr[p2] = arr[p2],arr[p1]
            p1+=1
            p2-=1
sol = Solution()
arr = [1, 2, 3, 4, 5]
print(arr)
sol.reverse(arr,5)
print(arr)
