n=5
i=1
while i<=n:
  if i==1:
    j=1
    while j<=n:
      print("*", end="")
      j=j+1
  elif i==n:
    j=1
    while j<=n:
      print("*", end="")
      j=j+1
  else:
    print("*", end="")
    j=1
    while j<=n-2:
      print(" ", end="")
      j=j+1
    print("*", end="")
  print()
  i=i+1
